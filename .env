# Audio Transcriber Configuration

# Maximum file size in MB (increase for longer files)
MAX_FILE_SIZE_MB=2000

# Supported audio formats
SUPPORTED_FORMATS=m4a,mp3,wav,aac,ogg,flac,wma

# Whisper model to use (tiny, base, small, medium, large)
WHISPER_MODEL=base

# Upload directory
UPLOAD_DIR=uploads

# Results directory
RESULTS_DIR=results

# Server configuration
HOST=127.0.0.1
PORT=8000

# Long audio file processing configuration
# Word timestamps: auto (disable for long files), true (always), false (never)
ENABLE_WORD_TIMESTAMPS=auto

# Maximum duration in minutes to use word timestamps (only applies when ENABLE_WORD_TIMESTAMPS=auto)
WORD_TIMESTAMP_MAX_DURATION=30

# Audio chunk length in minutes for long files
AUDIO_CHUNK_LENGTH_MINUTES=10

# Overlap between chunks in seconds to prevent word cutoff
CHUNK_OVERLAP_SECONDS=5

# Uvicorn timeout in seconds (0 = unlimited)
UVICORN_TIMEOUT=0
